<!doctype html>
<html lang="zh-CN">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ title }}</title>
  <style>
    :root {
      color-scheme: light;
      --ink: #1f2933;
      --muted: #52616b;
      --line: #d9e2ec;
      --accent: #0b5cad;
      --accent-soft: #eef6ff;
      --ok: #0f766e;
      --warn: #b45309;
      --bg: #f7f9fb;
      --paper: #ffffff;
    }
    body {
      margin: 0;
      background: var(--bg);
      color: var(--ink);
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "PingFang SC", "Microsoft YaHei", sans-serif;
      line-height: 1.68;
    }
    main {
      max-width: 980px;
      margin: 0 auto;
      padding: 40px 20px 64px;
      background: var(--paper);
      min-height: 100vh;
      box-sizing: border-box;
    }
    h1 {
      margin: 0 0 28px;
      font-size: 28px;
      line-height: 1.25;
      letter-spacing: 0;
    }
    h2 {
      margin: 32px 0 16px;
      padding-bottom: 8px;
      border-bottom: 1px solid var(--line);
      font-size: 20px;
      letter-spacing: 0;
    }
    h2:nth-of-type(1) {
      border-bottom-color: transparent;
      color: var(--accent);
    }
    h2:nth-of-type(2) + ul {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
      gap: 10px;
      padding-left: 0;
      list-style: none;
    }
    h2:nth-of-type(2) + ul li {
      margin: 0;
      padding: 12px 14px;
      border: 1px solid var(--line);
      border-radius: 8px;
      background: var(--accent-soft);
    }
    h2:nth-of-type(3) + ul {
      columns: 2;
    }
    p {
      margin: 10px 0;
    }
    ol, ul {
      padding-left: 1.6em;
    }
    li {
      margin: 6px 0;
    }
    table {
      width: 100%;
      border-collapse: collapse;
      margin: 14px 0 22px;
      font-size: 14px;
    }
    th, td {
      padding: 10px 12px;
      border: 1px solid var(--line);
      text-align: left;
      vertical-align: top;
    }
    th {
      background: #f1f5f9;
    }
    strong {
      color: #172033;
    }
    a {
      color: var(--accent);
      text-decoration: none;
    }
    a:hover {
      text-decoration: underline;
    }
    @media (max-width: 640px) {
      main {
        padding: 28px 16px 48px;
      }
      h1 {
        font-size: 24px;
      }
      h2 {
        font-size: 18px;
      }
      h2:nth-of-type(3) + ul {
        columns: 1;
      }
    }
  </style>
</head>
<body>
  <main>{{ body | safe }}</main>
</body>
</html>
